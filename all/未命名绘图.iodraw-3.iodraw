        <mxCell id="6xfGQL1O9mSxqX7nI121-76" value="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="325" y="670" width="60" height="30" as="geometry" />
