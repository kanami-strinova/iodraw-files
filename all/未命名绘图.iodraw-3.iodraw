        <mxCell id="6xfGQL1O9mSxqX7nI121-73" value="实习生参与" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="645" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="6xfGQL1O9mSxqX7nI121-74" value="" style="endArrow=none;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="6xfGQL1O9mSxqX7nI121-2" target="6xfGQL1O9mSxqX7nI121-73">
